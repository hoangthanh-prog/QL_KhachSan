@model List<QL_KhachSan.Models.LoaiPhong>


<nav class="navbar navbar-expand-lg navbar-dark" style="background-color: #00AEEF;">
    <!-- Nền navbar tối hơn để nổi bật -->
    <div class="container">
        <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <!-- Trang chủ -->
            <li class="nav-item">
                <a class="nav-link text-white fw-semibold px-3" href="@Url.Action("Index","Home")">
                    Trang chủ
                </a>
            </li>

            <!-- Menu Phòng - 3 cấp -->
            <li class="nav-item dropdown">
                <a class="nav-link dropdown-toggle text-white fw-semibold px-3"
                   href="@Url.Action("DanhSachBienThe","Phong")"
                   role="button"
                   data-bs-toggle="dropdown"
                   aria-expanded="false">
                    Phòng
                </a>
                <ul class="dropdown-menu shadow-lg border-0 rounded-4 py-3" style="min-width: 280px;">
                    <!-- Tiêu đề -->
                    <li>
                        <h6 class="dropdown-header text-uppercase fw-bold" style="color: #00AEEF; font-size: 0.95rem;">
                            Danh sách loại phòng
                        </h6>
                    </li>

                    <!-- Danh sách loại phòng động -->
                    @foreach (var i in Model)
                    {
                        <li class="dropdown-submenu position-relative">
                            <a class="dropdown-item py-2 px-4 rounded-2 d-flex align-items-center"
                               href="@Url.Action("DanhSachBienThe", "Phong", new { keyword = i.MaLoai })">
                                <i class="bi bi-door-open me-3 text-primary"></i>
                                <span>@i.TenLoai</span>
                            </a>
                            <ul class="dropdown-menu shadow-lg border-0 rounded-4 py-3" style="min-width: 220px;">
                                @foreach (var bt in i.BienThePhongs)
                                {
                                    <li>
                                        <a class="dropdown-item py-2 px-4 rounded-2" href="@Url.Action("DanhSachBienThe", "Phong", new 
                                                                                      { BienThe = bt.MaBienThe })">
                                            <i class="bi bi-tag-fill me-3" style="color: #00AEEF;"></i>@bt.BienThe
                                        </a>
                                    </li>
                                }
                            </ul>
                        </li>
                    }

                    <li><hr class="dropdown-divider mx-3 my-2" /></li>

                    <!-- Xem tất cả phòng -->
                    <li>
                        <a class="dropdown-item py-2 px-4 rounded-2 d-flex align-items-center"
                           href="@Url.Action("DanhSachBienThe","Phong")">
                            <i class="bi bi-list-ul me-3 text-muted"></i>
                            <span>Xem tất cả phòng</span>
                        </a>
                    </li>

                    <li><hr class="dropdown-divider mx-3 my-2" /></li>

                    <!-- Cấp 2: Thông tin phòng → cấp 3 -->
                    <li class="dropdown-submenu position-relative">
                        <a class="dropdown-item py-2 px-4 rounded-2 d-flex justify-content-between align-items-center fw-medium"
                           href="#">
                            <span><i class="bi bi-info-circle me-3" style="color: #00AEEF;"></i>Khác</span>
                            <i class="bi bi-chevron-right small opacity-75"></i>
                        </a>
                        <ul class="dropdown-menu shadow-lg border-0 rounded-4 py-3" style="min-width: 220px;">
                            <li>
                                <a class="dropdown-item py-2 px-4 rounded-2" href="@Url.Action("KhuyenMai","Home")">
                                    <i class="bi bi-tag-fill me-3" style="color: #00AEEF;"></i>Khuyến mãi
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item py-2 px-4 rounded-2" href="@Url.Action("DichVu","Home")">
                                    <i class="bi bi-gear-wide-connected me-3" style="color: #00AEEF;"></i>Dịch vụ
                                </a>
                            </li>
                        </ul>
                    </li>
                </ul>
            </li>
            <li class="nav-item">
                <a class="nav-link text-white fw-semibold px-3" href="@Url.Action("LienHe","Home")">
                    <i class="bi bi-telephone-fill me-3" style="color: #00AEEF;"></i>Liên hệ
                </a>
            </li>
            <li class="nav-item ">
                <a class="nav-link text-white fw-semibold px-3" href="@Url.Action("GioiThieu","Home")">
                    <i class="bi bi-building me-3" style="color: #00AEEF;"></i>Giới thiệu
                </a>
            </li>
        </ul>
    </div>
</nav>

<!-- CSS tùy chỉnh đẹp hơn với màu #00AEEF -->
<style>
    /* Navbar chính */
    .navbar {
        padding: 0.8rem 0;
    }

    .nav-link {
        transition: all 0.3s ease;
    }

        .nav-link:hover {
            color: white !important;
        }

    /* Dropdown item hover */
    .dropdown-item {
        transition: all 0.3s ease;
        margin: 2px 8px;
    }

        .dropdown-item:hover {
            background-color: #00AEEF;
            color: white !important;
        }

            .dropdown-item:hover i {
                color: white !important;
            }

    /* Submenu cấp 3 - mở sang phải */
    .dropdown-submenu {
        position: relative;
    }

        .dropdown-submenu > .dropdown-menu {
            top: 0;
            left: 100%;
            margin-top: -8px;
            margin-left: 0.1rem;
        }

    .dropdown:hover > .dropdown-menu {
        display: block;
    }

    .dropdown-submenu:hover > .dropdown-menu {
        display: block;
    }

    /* Ẩn mũi tên mặc định khi hover */
    .dropdown > .dropdown-toggle::after,
    .dropdown-submenu > .dropdown-item::after {
        display: none;
    }


    .dropdown-submenu > .dropdown-menu {
        position: static;
        float: none;
        width: 100%;
        margin-top: 0;
        background-color: #f8f9fa;
        border: 0;
        box-shadow: none;
    }

    .dropdown-submenu > .dropdown-item {
        justify-content: flex-start;
    }

        .dropdown-submenu > .dropdown-item > .bi-chevron-right {
            transform: rotate(90deg);
        }


    /* Bóng đổ và bo góc mượt */
    .dropdown-menu {
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.15);
    }
</style>
