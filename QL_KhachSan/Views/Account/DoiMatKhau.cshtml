
@{
    ViewBag.Title = "Đổi mật khẩu";
}

<div class="card mx-auto shadow-lg border-0" style="max-width: 600px; border-radius: 16px; overflow: hidden;">
    <div class="card-header text-white py-4 text-center"
         style="background: linear-gradient(135deg, #9C7A5A 0%, #B89F86 100%);">
        <h3 class="mb-0 fw-bold fs-4">Đổi mật khẩu</h3>
    </div>

    <div class="card-body p-4 p-lg-5 bg-light">
        <form asp-action="DoiMatKhau" asp-controller="Account" method="post">
            <!-- Anti-forgery token (bắt buộc trong ASP.NET Core) -->
            @Html.AntiForgeryToken()

            <div class="row g-4">
                <div class="col-12">
                    <label class="form-label fw-semibold" style="color: #8B6F47;">
                        Mật khẩu hiện tại <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input type="password" class="form-control form-control-lg"
                               name="MatKhauCu" required autocomplete="current-password" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword(this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold" style="color: #8B6F47;">
                        Mật khẩu mới <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input type="password" class="form-control form-control-lg"
                               name="MatKhauMoi" id="newPassword" required autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword(this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>

                <div class="col-12">
                    <label class="form-label fw-semibold" style="color: #8B6F47;">
                        Xác nhận mật khẩu mới <span class="text-danger">*</span>
                    </label>
                    <div class="input-group">
                        <input type="password" class="form-control form-control-lg"
                               name="XacNhanMatKhau" required autocomplete="new-password" />
                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword(this)">
                            <i class="fas fa-eye"></i>
                        </button>
                    </div>
                </div>
            </div>
            @if (ViewBag.Error != null)
            {
                <div class="alert alert-danger alert-dismissible fade show mt-4" role="alert">
                    @ViewBag.Error
                </div>
            }
            <hr class="my-5 border-secondary-subtle">

            <div class="d-flex justify-content-between">
                <a href="@Url.Action("Index", "Profile")" class="btn btn-lg btn-outline-secondary px-5">
                    Hủy bỏ
                </a>
                <button type="submit" class="btn btn-lg px-5 py-2 text-white shadow-sm"
                        style="background-color: #9C7A5A; border: none;">
                    <i class="fas fa-key me-2"></i>Cập nhật mật khẩu
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Script nhỏ để toggle hiển thị mật khẩu -->
<script>
    function togglePassword(button) {
        const input = button.closest('.input-group').querySelector('input');
        if (input.type === "password") {
            input.type = "text";
            button.innerHTML = '<i class="fas fa-eye-slash"></i>';
        } else {
            input.type = "password";
            button.innerHTML = '<i class="fas fa-eye"></i>';
        }
    }
</script>
