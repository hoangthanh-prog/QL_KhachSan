@model QL_KhachSan.Models.BienThePhong

@{
    ViewBag.Title = "Thêm biến thể phòng";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
}

<h3 class="mb-3">➕ Thêm biến thể phòng</h3>

@Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

@using (Html.BeginForm("Create", "BienThePhong",
        new { area = "Admin" },
        FormMethod.Post,
        new { enctype = "multipart/form-data" }))
{
    @Html.AntiForgeryToken()

    <!-- Biến thể -->
    <div class="mb-3">
        @Html.LabelFor(m => m.BienThe, new { @class = "form-label fw-bold" })
        @Html.TextBoxFor(m => m.BienThe, new
        {
            @class = "form-control",
            required = "required",
            maxlength = "100",
            placeholder = "VD: Phòng Deluxe hướng biển"
        })
        @Html.ValidationMessageFor(m => m.BienThe, "", new { @class = "text-danger" })
    </div>

    <!-- Giá bán -->
    <div class="mb-3">
        @Html.LabelFor(m => m.GiaBan, new { @class = "form-label fw-bold" })
        @Html.TextBoxFor(m => m.GiaBan, new
        {
            @class = "form-control",
            type = "number",
            step = "0.01",
            min = "0",
            placeholder = "VD: 1500000"
        })
        @Html.ValidationMessageFor(m => m.GiaBan, "", new { @class = "text-danger" })
    </div>
    <div class="mb-3">
        @Html.LabelFor(m => m.MaLoai, new { @class = "form-label fw-bold" })
        @Html.DropDownList("HangPhong", ViewBag.HangPhongList as SelectList,"--- Chọn hạng phòng ---", new { @class = "form-control" })
        @Html.ValidationMessageFor(m => m.MaLoai, "", new { @class = "text-danger" })
    </div>
    <!-- Mô tả -->
    <div class="mb-3">
        @Html.LabelFor(m => m.MoTa, new { @class = "form-label fw-bold" })
        @Html.TextAreaFor(m => m.MoTa, new
        {
            @class = "form-control",
            rows = 4,
            placeholder = "Nhập mô tả chi tiết cho biến thể phòng..."
        })
        @Html.ValidationMessageFor(m => m.MoTa, "", new { @class = "text-danger" })
    </div>

    <!-- Upload hình -->
    <div class="mb-3">
        <label class="form-label fw-bold">Ảnh biến thể</label>
        <input type="file" name="files" multiple class="form-control" />
        <small class="text-muted">Có thể chọn nhiều ảnh (.jpg, .png, .webp)</small>
    </div>

    <!-- Nút -->
    <div class="mt-4">
        <button type="submit" class="btn btn-success">
            💾 Lưu
        </button>
        @Html.ActionLink("⬅ Quay lại", "Index", null,
            new { @class = "btn btn-secondary ms-2" })
    </div>
}
