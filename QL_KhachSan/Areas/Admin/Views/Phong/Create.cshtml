@model QL_KhachSan.Models.Phong

@{
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    ViewBag.Title = "Thêm phòng";
}

<h3 class="mb-4">➕ Thêm phòng mới</h3>

@using (Html.BeginForm())
{
    @Html.AntiForgeryToken()

    <div class="card shadow-sm">
        <div class="card-body">

            <div class="mb-3">
                @Html.LabelFor(m => m.TenPhong, new { @class = "form-label fw-bold" })
                @Html.TextBoxFor(m => m.TenPhong, new { @class = "form-control" , placeholder = "VD: Phòng 103", required = "required" })
                @Html.ValidationMessageFor(m => m.TenPhong, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Biến thể phòng</label>
                @Html.DropDownListFor(
                    m => m.MaBienThe,
                    ViewBag.MaBienThe as SelectList,
                    "-- Chọn biến thể phòng --",
                    new { @class = "form-select", required = "required" }
                )
                @Html.ValidationMessageFor(m => m.MaBienThe, "", new { @class = "text-danger" })
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">Tình trạng phòng</label>
                @Html.DropDownListFor(
                    m => m.TinhTrang,
                    ViewBag.TinhTrang as SelectList,
                    "-- Chọn tình trạng --",
                    new { @class = "form-select", required = "required" }
                )
                @Html.ValidationMessageFor(m => m.TinhTrang, "", new { @class = "text-danger" })
            </div>

        </div>

        <div class="card-footer text-end">
            <button type="submit" class="btn btn-primary">💾 Lưu</button>
            <a href="@Url.Action("Index")" class="btn btn-secondary ms-2">⬅ Quay lại</a>
        </div>
    </div>
}
